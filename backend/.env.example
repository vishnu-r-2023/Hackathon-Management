PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/hackathon_management
JWT_SECRET=jwt_secret_key
JWT_EXPIRES_IN=7d

# If you want to allow creating admin/judge accounts via /api/auth/register,
# set this to a secret value and pass it as "bootstrapSecret" in the request body.
ROLE_BOOTSTRAP_SECRET=mysecret
